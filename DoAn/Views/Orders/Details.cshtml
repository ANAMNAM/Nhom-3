@model DoAn.Models.Order

<div class="container mt-4">
    <h2 class="text-primary mb-4">Chi tiết đơn hàng</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <p><b>Mã hóa đơn:</b> @Model.InvoiceCode</p>
            <p><b>Ngày đặt:</b> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
            <p><b>Phương thức:</b> @Model.PaymentMethod</p>
            <p><b>Trạng thái:</b> @Model.Status</p>
        </div>
    </div>

    <table class="table table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Sản phẩm</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Thành tiền</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.OrderItems)
            {
                <tr>
                    <td>@item.Product?.Name</td>
                    <td>@item.Quantity</td>
                    <td>@String.Format("{0:N0} đ", item.UnitPrice)</td>
                    <td>@String.Format("{0:N0} đ", item.TotalPrice)</td>
                </tr>
            }
        </tbody>
    </table>

    <h4 class="text-end text-danger">
        Tổng tiền: @String.Format("{0:N0} đ", Model.FinalAmount)
    </h4>

    <a asp-controller="Orders"
       asp-action="History"
       class="btn btn-secondary mt-3">
        ← Quay lại lịch sử
    </a>
</div>