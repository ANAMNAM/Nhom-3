@model List<DoAn.Models.Order>

<div class="container mt-4">
    <h2 class="text-primary mb-4">Lịch sử mua hàng</h2>

    @if (Model.Any())
    {
        foreach (var order in Model)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <strong>Mã hóa đơn:</strong> 
                    <a asp-controller="Orders"
                                                asp-action="Details"
                                                asp-route-id="@order.Id">
                    @order.InvoiceCode
                </a>
                    <span class="float-end">
                        @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                    </span>
                </div>

                <div class="card-body">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Số lượng</th>
                                <th>Đơn giá</th>
                                <th>Thành tiền</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in order.OrderItems)
                            {
                                <tr>
                                    <td>@item.Product?.Name</td>
                                    <td>@item.Quantity</td>
                                    <td>@String.Format("{0:N0} đ", item.UnitPrice)</td>
                                    <td>@String.Format("{0:N0} đ", item.TotalPrice)</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <h5 class="text-end text-danger">
                        Tổng tiền: @String.Format("{0:N0} đ", order.FinalAmount)
                    </h5>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info">
            Chưa có lịch sử mua hàng.
        </div>
    }
</div>