@model DoAn.Models.Account

<div class="container mt-4">
    <h2 class="text-primary mb-4">Thông tin khách hàng</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <p><b>Họ tên:</b> @Model.FullName</p>
            <p><b>Số điện thoại:</b> @Model.Phone</p>
            <p><b>Email:</b> @Model.Customer?.Email</p>
            <p><b>Địa chỉ:</b> @Model.Address</p>
            <p><b>Tài khoản:</b> @Model.Username</p>
        </div>
    </div>

    <a asp-controller="Account"
       asp-action="EditProfile"
       class="btn btn-warning">
        Chỉnh sửa thông tin
    </a>

    <a asp-controller="Orders"
       asp-action="History"
       class="btn btn-primary">
        Xem lịch sử mua hàng
    </a>
</div>