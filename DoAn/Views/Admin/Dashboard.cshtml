@model List<DoAn.Models.Order>
@{
    var bestSellingProducts = ViewBag.BestSellingProducts;
    var aprioriRules = ViewBag.AprioriRules as List<DoAn.Models.AssociationRule>;
}

<div class="container mt-4">
    <h2 class="text-primary mb-4">Trang quản trị</h2>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm border-primary">
                <div class="card-body">
                    <h5>Tổng đơn hàng</h5>
                    <h2>@ViewBag.TotalOrders</h2>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-success">
                <div class="card-body">
                    <h5>Tổng doanh thu</h5>
                    <h2 class="text-success">
                        @String.Format("{0:N0} đ", ViewBag.TotalRevenue)
                    </h2>
                </div>
            </div>
        </div>
    </div>

    <h4>Sản phẩm bán chạy</h4>

    <table class="table table-bordered mb-4">
        <thead class="table-light">
            <tr>
                <th>Sản phẩm</th>
                <th>Số lượng bán</th>
                <th>Doanh thu</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in bestSellingProducts)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.TotalQuantity</td>
                    <td>@String.Format("{0:N0} đ", item.TotalRevenue)</td>
                </tr>
            }
        </tbody>
    </table>
    <h4>Luật gợi ý Apriori</h4>

    <table class="table table-bordered mb-4">
        <thead class="table-light">
            <tr>
                <th>Sản phẩm đã mua</th>
                <th>Gợi ý mua kèm</th>
                <th>Support</th>
                <th>Confidence</th>
                <th>Lift</th>
            </tr>
        </thead>

        <tbody>
            @if (aprioriRules != null && aprioriRules.Any())
            {
                foreach (var rule in aprioriRules)
                {
                    <tr>
                        <td>
                            @string.Join(", ",
                                rule.AssociationRuleAntecedents
                                    .Select(x => x.Product.Name))
                        </td>

                        <td>
                            @string.Join(", ",
                                rule.AssociationRuleConsequents
                                    .Select(x => x.Product.Name))
                        </td>

                        <td>@rule.SupportValue</td>
                        <td>@rule.ConfidenceValue</td>
                        <td>@rule.LiftValue</td>
                    </tr>
                }
            }
        </tbody>
    </table>
    <h4>Danh sách đơn hàng</h4>

    <table class="table table-bordered">
        <thead class="table-light">
            <tr>
                <th>Mã hóa đơn</th>
                <th>Khách hàng</th>
                <th>Ngày đặt</th>
                <th>Tổng tiền</th>
                <th>Thanh toán</th>
                <th>Trạng thái</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.InvoiceCode</td>
                    <td>@order.Customer?.FullName</td>
                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@String.Format("{0:N0} đ", order.FinalAmount)</td>
                    <td>@order.PaymentMethod</td>
                    <td>@order.Status</td>
                </tr>
            }
        </tbody>
    </table>
</div>