@model DoAn.Models.Product

@{
    var recommendations = ViewBag.Recommendations as List<DoAn.Models.Product>;
}

<div class="container mt-4">

    <h2 class="mb-4 text-primary">Chi tiết sản phẩm</h2>

    <div class="card shadow-sm mb-5">
        <div class="row g-0">
            <div class="col-md-5">
                <img src="/images/products/@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "no-image.jpg" : Model.ImageUrl)"
                     class="img-fluid rounded-start"
                     style="width:100%;height:360px;object-fit:cover;" />
            </div>

            <div class="col-md-7">
                <div class="card-body p-4">
                    <h1 class="h3 mb-3">@Model.Name</h1>

                    <p class="text-muted mb-2">
                        Mã sản phẩm: <strong>@($"SP{Model.Id:000}")</strong>
                    </p>

                    <h2 class="text-danger mb-4">
                        @String.Format("{0:N0} đ", Model.BasePrice)
                    </h2>

                    <a asp-controller="Cart"
                       asp-action="Add"
                       asp-route-id="@Model.Id"
                       class="btn btn-success btn-lg">
                        🛒 Thêm vào giỏ hàng
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Sản phẩm thường mua cùng</h3>

        <a asp-controller="Cart"
           asp-action="Index"
           class="btn btn-outline-success">
            Xem giỏ hàng
        </a>
    </div>

    @if (recommendations != null && recommendations.Any())
    {
        <div class="row">
            @foreach (var item in recommendations)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm">

                        <img src="/images/products/@(string.IsNullOrWhiteSpace(item.ImageUrl) ? "no-image.jpg" : item.ImageUrl)"
                             class="card-img-top"
                             style="height:180px;object-fit:cover;" />

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.Name</h5>

                            <p class="text-danger fw-bold">
                                @String.Format("{0:N0} đ", item.BasePrice)
                            </p>

                            <div class="mt-auto d-grid gap-2">
                                <a asp-controller="Products"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-primary">
                                    Xem sản phẩm
                                </a>

                                <a asp-controller="Cart"
                                   asp-action="Add"
                                   asp-route-id="@item.Id"
                                   class="btn btn-success">
                                    🛒 Mua kèm
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Chưa có sản phẩm gợi ý.
        </div>
    }

    <a asp-controller="Products"
       asp-action="Index"
       class="btn btn-secondary mt-3">
        ← Quay lại danh sách
    </a>

</div>